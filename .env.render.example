APP_NAME=Auctify
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://web-system-auctify.onrender.com

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=aws-0-ap-southeast-1.pooler.supabase.com
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres.zakjudasfkoahkupdnju
DB_PASSWORD=your-supabase-database-password
DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

CACHE_STORE=database
QUEUE_CONNECTION=database

SANCTUM_STATEFUL_DOMAINS=web-system-auctify.onrender.com
CORS_ALLOWED_ORIGINS=https://web-system-auctify.onrender.com
FRONTEND_URL=https://web-system-auctify.onrender.com

MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://web-system-auctify.onrender.com/api/auth/google/callback

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_ENABLED=true
SUPABASE_STORAGE_BUCKET=media

VERIFICATION_SHOW_DEV_OTP=false

RUN_MIGRATIONS=true
SKIP_MIGRATIONS_IF_SCHEMA_PRESENT=true
RUN_SEEDERS=true
SEED_ADMIN_EMAIL=admin@auctify.com
SEED_ADMIN_PASSWORD=1234567890Qwertyuiop@